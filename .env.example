# Optional. Gemini CLI can use cached CLI auth, but the API adapter path can use this later.
GEMINI_API_KEY=

# Optional. Enables OpenAI API panels. Use a data-sharing-enabled project only
# for non-confidential prompts if you want OpenAI's complimentary daily tokens.
OPENAI_API_KEY=
OPENAI_PROJECT=

# Optional. Enables OpenRouter-backed panel presets such as openrouter-thrift,
# openrouter-budget, and hybrid-budget.
OPENROUTER_API_KEY=
OPENROUTER_HTTP_REFERER=
OPENROUTER_TITLE=Fusion Lite

# Optional. Enables the DeepSeek API panel member.
DEEPSEEK_API_KEY=
